# ── Authentication ──────────────────────────────────────
AUTH_SECRET=your-auth-secret-32-bytes-base64  # JWT signing key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
ADMIN_EMAIL=you@example.com                   # Google email for bootstrap admin account

# ── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id        # Google OAuth client ID
GOOGLE_CLIENT_SECRET=your-google-secret       # Google OAuth client secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google  # OAuth callback URL

# ── Cron & Admin ────────────────────────────────────────
CRON_SECRET=your-cron-secret                  # Bearer token for cron jobs and admin routes

# ── Upstash Redis ───────────────────────────────────────
KV_REST_API_URL=https://your-redis.upstash.io # Upstash Redis REST URL
KV_REST_API_TOKEN=your-upstash-token          # Upstash Redis REST token

# ── External APIs ───────────────────────────────────────
POSTBRIDGE_API_KEY=your-postbridge-key        # PostBridge API key for TikTok/Instagram posting
GEMINI_API_KEY=your-gemini-key                # Google Gemini API key for image generation

# ── Optional ────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-key        # Enables AI slide text generation
